---
// Base layout — шрифты, meta, grain overlay, scroll progress, глобальный motion-layer
import "../styles/global.css";
import CustomCursor from "../components/islands/CustomCursor.tsx";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Vibe Machine — студия короткого видео. От 50 до 1 000 роликов в месяц.",
  description = "Единственный канал, который даёт охваты в 2026 — вертикальное короткое видео. Мы его строим. TikTok · Reels · Shorts · ВК Видео.",
  ogImage = "/og.png",
} = Astro.props;
---

<!doctype html>
<html lang="ru" class="bg-[var(--color-bg-0)] text-[var(--color-text-0)]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="ru_RU" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Theme color -->
    <meta name="theme-color" content="#000000" />

    <!-- Fonts — только нужные веса (6 вместо 17), display=swap для non-blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Unbounded:wght@700;800&family=Manrope:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Unbounded:wght@700;800&family=Manrope:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap"
      media="print" onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Unbounded:wght@700;800&family=Manrope:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap" />
    </noscript>
  </head>
  <body class="grain">
    <!-- Scroll progress bar -->
    <div id="scroll-progress" class="scroll-progress"></div>

    <!-- Custom cursor island — desktop only -->
    <CustomCursor client:load />

    <slot />

    <!-- Simple scroll-progress tracker (vanilla, no deps) -->
    <script is:inline>
      (function () {
        const bar = document.getElementById("scroll-progress");
        if (!bar) return;
        const update = () => {
          const doc = document.documentElement;
          const scrolled = doc.scrollTop / (doc.scrollHeight - doc.clientHeight);
          bar.style.setProperty("--scroll-progress", String(scrolled || 0));
        };
        window.addEventListener("scroll", update, { passive: true });
        window.addEventListener("resize", update);
        update();
      })();
    </script>

    <!-- IntersectionObserver — [data-reveal] gets .animate-reveal-up + .in-view -->
    <script is:inline>
      (function () {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("animate-reveal-up", "in-view");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -60px 0px" }
        );
        document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));

        // Убираем will-change после окончания анимации — 24+ compositor layers → 0
        document.addEventListener("animationend", function (e) {
          var n = e.animationName;
          if (n === "kineticReveal" || n === "revealUp" || n === "pulseGlow") return;
          e.target.style.willChange = "auto";
        }, { passive: true, capture: true });

        // kineticReveal — убираем will-change после last word (longest delay + duration)
        document.querySelectorAll(".kinetic-word").forEach(function(el) {
          el.addEventListener("animationend", function() {
            el.style.willChange = "auto";
          }, { once: true, passive: true });
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
  }

  /* Section spacing — tighter, content-driven */
  section.block {
    padding: 4rem 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    /* content-visibility:auto УБРАН — Safari layout jank при входе секций */
  }
  @media (min-width: 768px) {
    section.block {
      padding: 5.5rem 3rem;
    }
  }
  @media (min-width: 1280px) {
    section.block {
      padding: 7rem 6rem;
    }
  }

  /* Hero + CTA finale — фулл viewport для удара, остальные — по контенту */
  section.block-tall {
    min-height: 90vh;      /* fallback for older browsers */
    min-height: 90dvh;     /* dynamic viewport height — accounts for mobile address bar */
  }

  /* Smooth anchor scroll — нативный CSS, compositor-threaded, 0 JS */
  html {
    scroll-behavior: smooth;
  }
  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
  }

  /* Custom cursor — hide native when active */
  html.has-custom-cursor,
  html.has-custom-cursor * {
    cursor: none !important;
  }

  /* ── Reveal system fix ──────────────────────────────────────────
     Элементы СКРЫТЫ до появления в viewport.
     Без этого: элемент видим → IO добавляет .animate-reveal-up →
     animation 'both' ставит opacity:0 → flash исчезания.
     ─────────────────────────────────────────────────────────────── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    /* Не transition — animate-reveal-up сам управляет движением */
  }

  /* После того как IO добавил класс — снять инлайновый стиль */
  [data-reveal].animate-reveal-up {
    opacity: 1;
    transform: none;
  }

  /* Section divider — thin yellow line between blocks */
  .section-divider {
    display: block;
    width: 100%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(255, 204, 0, 0.3) 50%,
      transparent
    );
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  .section-divider.in-view {
    opacity: 1;
  }
</style>
