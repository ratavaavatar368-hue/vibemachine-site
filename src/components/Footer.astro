---
const YEAR = new Date().getFullYear();
---

<footer
  class="relative border-t border-white/5 py-8 md:py-12 px-6 md:px-12"
>
  <div
    class="max-w-[1440px] mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-6"
  >
    <div class="flex items-center gap-3">
      <span class="text-[var(--color-accent)] text-lg">⚡</span>
      <span
        class="font-display font-extrabold text-sm tracking-[-0.02em]"
        >VIBE MACHINE</span
      >
    </div>

    <div
      class="font-mono text-xs text-[var(--color-text-2)] flex flex-col md:flex-row md:items-center gap-2 md:gap-6"
    >
      <span>© {YEAR} VIBECONTORA</span>
      <a
        href="https://t.me/vibemachine_bot"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-[var(--color-accent)] transition-colors"
      >
        Telegram-бот
      </a>
      <a href="#" class="hover:text-[var(--color-accent)] transition-colors"
        >Политика</a
      >
      <a href="#" class="hover:text-[var(--color-accent)] transition-colors"
        >Оферта</a
      >
    </div>
  </div>
</footer>
