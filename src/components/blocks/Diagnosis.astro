---
// БЛОК 2 — ДИАГНОЗ
// «2026. В РФ. Платный трафик сломан.»
// 4 зачёркнутых канала — CSS-анимация линии через transform

const channels = [
  {
    icon: "🧨",
    name: "ДИРЕКТ",
    verdict: "Дорожает. Тает.",
    note: "CPC растёт. Конверсия падает.",
  },
  {
    icon: "⛔",
    name: "ТАРГЕТ",
    verdict: "Недоступен.",
    note: "Meta Ads — всё. Google — с ограничениями.",
  },
  {
    icon: "📉",
    name: "БЛОГЕРЫ",
    verdict: "Раздуты. Не измерить.",
    note: "Рынок перегрет ×2–×5 за два года.",
  },
  {
    icon: "⏳",
    name: "SEO",
    verdict: "Слишком долго.",
    note: "Первые результаты — через 6–12 месяцев.",
  },
];
---

<section id="diagnosis" class="block relative">
  <div class="max-w-[1280px] mx-auto w-full">
    <!-- Eyebrow -->
    <div class="flex justify-center lg:justify-start mb-6" data-reveal>
      <div class="eyebrow">Платный трафик · 2026</div>
    </div>

    <!-- Headline -->
    <h2
      class="h-display text-[clamp(2rem,5.5vw,4rem)] mb-6 max-w-[22ch] text-center lg:text-left mx-auto lg:mx-0"
      data-reveal
    >
      Четыре канала. <br />
      <span class="text-[var(--color-text-1)]"
        >Четыре разных способа потерять бюджет.&thinsp;❌</span
      >
    </h2>

    <p
      class="text-lg text-[var(--color-text-1)] max-w-[50ch] mb-16 text-center lg:text-left mx-auto lg:mx-0"
      data-reveal
      style="animation-delay:120ms"
    >
      У каждого бренда в РФ одна и та же картина. Бюджет на маркетинг
      остался — а тратить его стало некуда.
    </p>

    <!-- 4 карточки сломанных каналов -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 mb-20"
    >
      {
        channels.map((ch, i) => (
          <div
            class="card-base diagnosis-card relative overflow-hidden"
            data-reveal
            style={`animation-delay:${240 + i * 100}ms`}
          >
            <div class="text-3xl mb-4">{ch.icon}</div>
            <div class="channel-name font-mono text-base text-[var(--color-text-0)] tracking-widest uppercase mb-2">
              {ch.name}
            </div>
            <div class="h-display text-2xl md:text-3xl mb-2">
              {ch.verdict}
            </div>
            <div class="text-sm text-[var(--color-text-1)] leading-relaxed">
              {ch.note}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Transition banner — тёмный стиль с жёлтым акцентом -->
    <div class="diagnosis-banner" data-reveal style="animation-delay:800ms">
      <div class="diagnosis-banner__line" aria-hidden="true"></div>
      <p class="diagnosis-banner__title">
        Остался один канал.<br />
        <span class="text-gradient-hero">Короткие вертикальные&nbsp;видео.</span>
      </p>
      <p class="diagnosis-banner__sub">
        TikTok · Reels · Shorts · ВК&nbsp;Видео
      </p>
      <div class="diagnosis-banner__line" aria-hidden="true"></div>
    </div>
  </div>
</section>

<style>
  /* ── Strikethrough на названии канала (ДИРЕКТ / ТАРГЕТ / etc.) ── */
  .diagnosis-card .channel-name {
    position: relative;
    display: inline-block;
  }

  /* Линия зачёркивания — рисуется слева направо при входе в вьюпорт */
  .diagnosis-card .channel-name::after {
    content: "";
    position: absolute;
    left: -4px;
    right: -4px;
    top: 50%;
    margin-top: -2px;
    height: 4px;
    border-radius: 2px;
    background: linear-gradient(
      90deg,
      #ffcc00 0%,
      #ff8c00 50%,
      #ff6b35 100%
    );
    box-shadow: 0 0 10px rgba(255, 140, 0, 0.8), 0 0 20px rgba(255, 140, 0, 0.4);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.3s;
    pointer-events: none;
  }

  /* Trigger: IntersectionObserver добавляет .in-view к карточке */
  .diagnosis-card.animate-reveal-up .channel-name::after,
  .diagnosis-card.in-view .channel-name::after {
    transform: scaleX(1);
  }

  /* Цвет текста при зачёркивании — чуть приглушённее, но читаемо */
  .diagnosis-card.in-view .channel-name,
  .diagnosis-card.animate-reveal-up .channel-name {
    transition: color 0.4s ease 0.2s;
    color: var(--color-text-1);
  }

  @media (prefers-reduced-motion: reduce) {
    .diagnosis-card .channel-name::after {
      transform: scaleX(1);
      transition: none;
    }
  }

  /* ── Transition banner — тёмный стиль с жёлтыми линиями ── */
  .diagnosis-banner {
    margin-left: -1.5rem;
    margin-right: -1.5rem;
    margin-bottom: -4rem;
    padding: 3rem 1.5rem;
    text-align: center;
    background: var(--color-bg-0);
    position: relative;
  }

  @media (min-width: 768px) {
    .diagnosis-banner {
      margin-left: -3rem;
      margin-right: -3rem;
      margin-bottom: -5.5rem;
      padding: 4rem 3rem;
    }
  }

  @media (min-width: 1280px) {
    .diagnosis-banner {
      margin-left: -6rem;
      margin-right: -6rem;
      margin-bottom: -7rem;
      padding: 5rem 6rem;
    }
  }

  /* Жёлтые горизонтальные линии сверху и снизу */
  .diagnosis-banner__line {
    width: 100%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(255, 204, 0, 0.5) 30%,
      rgba(255, 204, 0, 0.8) 50%,
      rgba(255, 204, 0, 0.5) 70%,
      transparent
    );
    margin: 0 auto 2rem;
  }

  .diagnosis-banner__line:last-child {
    margin: 2rem auto 0;
  }

  .diagnosis-banner__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.75rem, 5vw, 3.75rem);
    line-height: 1.1;
    color: var(--color-text-0);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .diagnosis-banner__sub {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-2);
    margin: 0;
  }
</style>
