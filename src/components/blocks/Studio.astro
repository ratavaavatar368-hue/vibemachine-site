---
// БЛОК 3 — СТУДИЯ + TEAM
// H2: «Трафик и контент. Один подрядчик. Ноль продакшн-headache.»
// + Team manifesto (10+ лет маркетинг, 5+ лет IT)
import CountUp from "../islands/CountUp.tsx";
---

<section id="studio" class="block relative">
  <div class="max-w-[1440px] mx-auto w-full">
    <!-- Eyebrow -->
    <div class="eyebrow mb-6" data-reveal>Vibe Machine</div>

    <!-- Grid: текст слева, reel placeholder справа -->
    <div class="grid lg:grid-cols-[1.15fr_1fr] gap-12 lg:gap-16 items-center">
      <!-- LEFT: copy -->
      <div>
        <h2
          class="h-display text-[clamp(2rem,5vw,3.75rem)] mb-6 max-w-[18ch]"
          data-reveal
        >
          Трафик и&nbsp;контент. <br />
          Один подрядчик. <br />
          <span class="text-gradient-hero">Ноль продакшн-headache.</span>
        </h2>

        <p
          class="text-lg text-[var(--color-text-1)] max-w-[42ch] mb-10"
          data-reveal
          style="animation-delay:120ms"
        >
          Обычно это 3 контракта: стратег, студия-продакшн, медиа-баер.
          У&nbsp;нас&nbsp;— один.
        </p>

        <!-- Three lines stagger -->
        <div class="space-y-4 mb-10">
          <p
            class="text-lg md:text-xl leading-snug"
            data-reveal
            style="animation-delay:240ms"
          >
            <span class="text-[var(--color-accent)] font-semibold"
              >Под капотом</span
            >
            <span class="text-[var(--color-text-1)]"
              >&nbsp;— лучшие инструменты и специалисты.</span
            >
          </p>
          <p
            class="text-lg md:text-xl leading-snug"
            data-reveal
            style="animation-delay:400ms"
          >
            <span class="text-[var(--color-accent)] font-semibold">Снаружи</span>
            <span class="text-[var(--color-text-1)]"
              >&nbsp;— поток роликов студийного качества.</span
            >
          </p>
          <p
            class="text-lg md:text-xl leading-snug"
            data-reveal
            style="animation-delay:560ms"
          >
            <span class="text-[var(--color-accent)] font-semibold">Объём</span>
            <span class="text-[var(--color-text-1)]"
              >&nbsp;— от&nbsp;<strong class="text-[var(--color-text-0)]">50</strong>
              до&nbsp;<strong class="text-[var(--color-text-0)]">1&nbsp;000</strong> в&nbsp;месяц.</span
            >
          </p>
        </div>

        <!-- Формат ролика — одна строка -->
        <div
          class="pt-6 border-t border-white/10"
          data-reveal
          style="animation-delay:680ms"
        >
          <div class="font-mono text-xs text-[var(--color-text-2)] uppercase tracking-widest mb-3">
            Состав одного ролика
          </div>
          <div class="flex flex-wrap gap-3">
            {
              [
                { icon: "💫", label: "Моушен", color: "var(--color-accent)" },
                { icon: "📊", label: "Инфографика", color: "var(--color-warn)" },
                { icon: "▶", label: "B-roll", color: "var(--color-info)" },
                { icon: "🧑", label: "AI-аватар", color: "#A855F7" },
                { icon: "T", label: "Субтитры", color: "#fff" },
                { icon: "♪", label: "Голос", color: "var(--color-accent)" },
                { icon: "🎛", label: "Саунд-дизайн", color: "var(--color-warn)" },
              ].map((l) => (
                <div class="flex items-center gap-2 px-3 py-2 rounded-lg bg-white/[0.03] border border-white/5">
                  <span
                    class="w-6 h-6 rounded-md flex items-center justify-center text-xs font-bold"
                    style={`background:${l.color};color:var(--color-bg-0)`}
                  >
                    {l.icon}
                  </span>
                  <span class="text-sm text-[var(--color-text-1)]">{l.label}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- RIGHT: reel slider with real videos -->
      <div class="relative flex flex-col items-center" data-reveal style="animation-delay:160ms">

        <!-- Phone mock + arrows row -->
        <div class="flex items-center gap-4">

          <!-- Prev arrow -->
          <button
            id="reel-prev"
            aria-label="Предыдущее видео"
            class="reel-arrow"
          >
            ‹
          </button>

          <!-- Phone mock -->
          <div class="reel-phone">
            <!-- Top bar -->
            <div class="flex items-center gap-2 mb-auto relative z-10 p-5 pb-0">
              <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
              <span class="font-mono text-xs text-[var(--color-text-2)] uppercase tracking-widest">DEMO REEL</span>
            </div>

            <!-- Videos (stacked, show one at a time) -->
            <div class="reel-videos">
              <video
                id="reel-video-0"
                src="/videos/video-1.mp4"
                autoplay muted loop playsinline preload="metadata"
                class="reel-vid active"
              ></video>
              <video
                id="reel-video-1"
                src="/videos/video-2.mp4"
                muted loop playsinline preload="metadata"
                class="reel-vid"
              ></video>
            </div>

            <!-- Bottom caption -->
            <div class="relative z-10 p-5 pt-0 mt-auto">
              <div class="font-mono text-xs text-[var(--color-text-2)] mb-1">@vibemachine</div>
              <div id="reel-caption" class="text-sm text-[var(--color-text-0)] leading-snug">Ролик 1 из 2</div>
            </div>
          </div>

          <!-- Next arrow -->
          <button
            id="reel-next"
            aria-label="Следующее видео"
            class="reel-arrow"
          >
            ›
          </button>
        </div>

        <!-- Dots -->
        <div class="flex gap-2 mt-5">
          <span class="reel-dot active" data-idx="0"></span>
          <span class="reel-dot" data-idx="1"></span>
        </div>

        <!-- Mini stats -->
        <div class="mt-6 flex justify-center items-center gap-6 text-center font-mono text-xs text-[var(--color-text-2)]">
          <div>
            <div class="text-[var(--color-accent)] text-lg font-bold">50+</div>
            <div>роликов / мес</div>
          </div>
          <div class="w-px h-8 bg-white/10"></div>
          <div>
            <div class="text-[var(--color-accent)] text-lg font-bold">9:16</div>
            <div>студийно</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Team / Expertise — manifesto block -->
    <div
      class="mt-20 md:mt-28 card-base max-w-[1120px] mx-auto"
      data-reveal
      style="animation-delay:400ms"
    >
      <div class="grid md:grid-cols-[1.4fr_1fr] gap-10 md:gap-14 items-center">
        <!-- LEFT: manifesto -->
        <div>
          <div class="eyebrow mb-5">Команда</div>
          <h3
            class="h-display text-[clamp(1.5rem,3.5vw,2.5rem)] mb-5 max-w-[18ch]"
          >
            Маркетинг и&nbsp;технологии.
            <span class="text-gradient-hero">Одна голова.</span>
          </h3>
          <p
            class="text-base md:text-lg text-[var(--color-text-1)] leading-relaxed max-w-[52ch]"
          >
            Креативное мышление и&nbsp;техническое — не&nbsp;две разных профессии.
            Это одно и&nbsp;то&nbsp;же, просто повёрнутое разными сторонами.
            На&nbsp;этом стыке рождается системный, рабочий креатив.
          </p>
        </div>

        <!-- RIGHT: 2 big metrics with count-up -->
        <div class="flex flex-col gap-5">
          <div class="flex items-baseline gap-4 pb-5 border-b border-white/10">
            <div
              class="font-display font-extrabold text-5xl md:text-6xl text-gradient-hero leading-none tracking-tight tabular-nums"
            >
              <CountUp client:visible to={10} suffix="+" duration={1600} />
            </div>
            <div>
              <div
                class="font-mono text-xs text-[var(--color-text-2)] uppercase tracking-widest"
              >
                лет
              </div>
              <div class="text-[var(--color-text-0)] text-base md:text-lg">
                в маркетинге
              </div>
            </div>
          </div>

          <div class="flex items-baseline gap-4">
            <div
              class="font-display font-extrabold text-5xl md:text-6xl text-gradient-hero leading-none tracking-tight tabular-nums"
            >
              <CountUp client:visible to={5} suffix="+" duration={1300} />
            </div>
            <div>
              <div
                class="font-mono text-xs text-[var(--color-text-2)] uppercase tracking-widest"
              >
                лет
              </div>
              <div class="text-[var(--color-text-0)] text-base md:text-lg">
                в IT и технологиях
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Phone mock ── */
  .reel-phone {
    position: relative;
    width: 260px;
    flex-shrink: 0;
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 36px;
    background: linear-gradient(145deg, var(--color-bg-2), var(--color-bg-1));
    box-shadow: var(--shadow-card), 0 0 40px rgba(255,204,0,0.07);
    display: flex;
    flex-direction: column;
    aspect-ratio: 9 / 16;
    overflow: hidden;
  }

  @media (min-width: 1280px) {
    .reel-phone { width: 300px; }
  }

  /* Videos container */
  .reel-videos {
    position: absolute;
    inset: 0;
    border-radius: 34px;
    overflow: hidden;
  }

  .reel-vid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .reel-vid.active {
    opacity: 1;
  }

  /* Arrow buttons */
  .reel-arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text-0);
    font-size: 1.5rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color 200ms, background 200ms, transform 200ms;
  }

  .reel-arrow:hover {
    border-color: rgba(255, 204, 0, 0.5);
    background: rgba(255, 204, 0, 0.08);
    transform: scale(1.08);
  }

  /* Dots */
  .reel-dot {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    transition: background 250ms, transform 250ms;
  }

  .reel-dot.active {
    background: var(--color-accent);
    transform: scale(1.3);
  }
</style>

<script is:inline>
  (function () {
    const videos = document.querySelectorAll('.reel-vid');
    const dots   = document.querySelectorAll('.reel-dot');
    const caption = document.getElementById('reel-caption');
    const captions = ['Ролик 1 из 2', 'Ролик 2 из 2'];
    let current = 0;

    function goTo(idx) {
      // pause old
      videos[current].pause();
      videos[current].classList.remove('active');
      dots[current].classList.remove('active');

      current = idx;

      videos[current].classList.add('active');
      videos[current].play().catch(() => {});
      dots[current].classList.add('active');
      if (caption) caption.textContent = captions[current];
    }

    document.getElementById('reel-prev')?.addEventListener('click', () => {
      goTo(current === 0 ? videos.length - 1 : current - 1);
    });

    document.getElementById('reel-next')?.addEventListener('click', () => {
      goTo(current === videos.length - 1 ? 0 : current + 1);
    });

    dots.forEach((dot) => {
      dot.addEventListener('click', () => goTo(+dot.dataset.idx));
    });
  })();
</script>
