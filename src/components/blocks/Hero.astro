---
// БЛОК 1 — HERO
// CSS-animated plasma glow background — 0 KB JS (removed Three.js/R3F)
import KineticText from "../KineticText.astro";
import MagneticButton from "../islands/MagneticButton.tsx";
import TelegramIcon from "../TelegramIcon.astro";

const TELEGRAM_BOT_URL = "https://t.me/vibemachine_bot";
---

<section
  id="top"
  class="block block-tall relative overflow-hidden"
>
  <!-- CSS plasma glow — animated radial gradient, 0 KB JS -->
  <div class="hero-plasma" aria-hidden="true"></div>

  <div
    class="relative z-10 max-w-[1200px] mx-auto text-center flex flex-col items-center"
  >
    <!-- H1 — kinetic typography (CSS-only) -->
    <KineticText
      as="h1"
      lines={[
        { text: "Остался один канал." },
        { text: "Мы его строим.", className: "text-gradient-hero" },
      ]}
      className="h-display text-[clamp(2rem,7vw,6.5rem)] mb-8 max-w-[18ch]"
      stagger={0.09}
      delay={0.15}
    />

    <!-- Sub — 2-в-1 -->
    <p
      class="text-lg md:text-xl text-[var(--color-text-1)] max-w-[32ch] mb-12 leading-snug"
      data-reveal
      style="animation-delay:900ms"
    >
      Трафик и контент — в&nbsp;одном решении.
      <br />
      Над продакшеном думаем мы.
    </p>

    <!-- CTAs -->
    <div
      class="flex flex-col sm:flex-row items-center gap-4 mb-16"
      data-reveal
      style="animation-delay:1100ms"
    >
      <MagneticButton
        client:load
        href={TELEGRAM_BOT_URL}
        target="_blank"
        rel="noopener noreferrer"
        className="btn-primary"
      >
        <TelegramIcon size={18} />
        <span>Запустить поток</span>
      </MagneticButton>

      <a
        href={TELEGRAM_BOT_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="link-arrow flex items-center gap-2 text-base"
      >
        <TelegramIcon size={16} />
        <span>Написать в Telegram</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <!-- Platform strip -->
    <div
      class="flex flex-wrap items-center justify-center gap-2"
      data-reveal
      style="animation-delay:1300ms"
    >
      <span class="platform-chip">TikTok</span>
      <span class="platform-chip">Instagram&nbsp;Reels</span>
      <span class="platform-chip">YouTube&nbsp;Shorts</span>
      <span class="platform-chip">ВК&nbsp;Видео</span>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    aria-hidden="true"
    class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-[var(--color-text-2)] text-xs z-10"
  >
    <span class="font-mono uppercase tracking-widest">Листай</span>
    <span
      class="block w-[1px] h-8 bg-gradient-to-b from-[var(--color-accent)] to-transparent"
    ></span>
  </div>
</section>

<style>
  /* ── CSS Plasma Glow — replaces Three.js/R3F (saves ~1 MB JS) ── */
  .hero-plasma {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  /* Main amber halo — sits behind the ⚡ icon
     blur встроен прямо в radial-gradient (через мягкие stops) вместо
     дорогостоящего filter:blur(), который форсит GPU recomposite */
  .hero-plasma::before {
    content: "";
    position: absolute;
    top: 4%;
    left: 50%;
    width: min(820px, 85vw);
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(
      ellipse at center,
      rgba(255, 195, 0, 0.22)  0%,
      rgba(255, 160, 0, 0.14) 22%,
      rgba(255, 120, 0, 0.07) 45%,
      rgba(255, 80,  0, 0.02) 65%,
      transparent 80%
    );
    /* NO filter:blur — saves GPU layer recomposition */
    transform: translateX(-50%);
    animation: plasmaBreath 5s ease-in-out infinite;
    will-change: opacity;           /* только opacity — cheap */
  }

  /* Secondary warm core */
  .hero-plasma::after {
    content: "";
    position: absolute;
    top: 3%;
    left: 50%;
    width: min(380px, 42vw);
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 185, 0, 0.36) 0%,
      rgba(255, 140, 0, 0.14) 40%,
      transparent 68%
    );
    transform: translateX(-50%);
    animation: plasmaCore 7s ease-in-out infinite;
    will-change: opacity;
  }

  @keyframes plasmaBreath {
    0%, 100% { opacity: 0.5; }
    50%       { opacity: 1;   }
  }

  @keyframes plasmaCore {
    0%, 100% { opacity: 0.35; }
    40%       { opacity: 0.9;  }
    70%       { opacity: 0.45; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-plasma::before,
    .hero-plasma::after {
      animation: none;
      opacity: 0.6;
    }
  }
</style>
