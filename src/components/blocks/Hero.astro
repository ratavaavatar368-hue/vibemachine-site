---
// БЛОК 1 — HERO
// CSS-animated plasma glow background — 0 KB JS (removed Three.js/R3F)
import KineticText from "../KineticText.astro";
import MagneticButton from "../islands/MagneticButton.tsx";
import TelegramIcon from "../TelegramIcon.astro";

const TELEGRAM_BOT_URL = "https://t.me/vibemachine_bot";
---

<section
  id="top"
  class="block block-tall relative overflow-hidden"
>
  <!-- CSS plasma glow — animated radial gradient, 0 KB JS -->
  <div class="hero-plasma" aria-hidden="true"></div>

  <div
    class="relative z-10 max-w-[1200px] mx-auto text-center flex flex-col items-center"
  >
    <!-- ⚡ big mark -->
    <div
      class="mb-8 md:mb-12 w-24 h-24 md:w-32 md:h-32 rounded-full bg-black/60 backdrop-blur-md flex items-center justify-center animate-pulse-glow border border-[rgba(255,204,0,0.32)]"
    >
      <span class="text-5xl md:text-6xl text-gradient-hero">⚡</span>
    </div>

    <!-- Brand -->
    <div
      class="mb-10 md:mb-14 font-mono text-xs md:text-sm tracking-[0.2em] text-[var(--color-text-2)] uppercase"
    >
      VIBE MACHINE
    </div>

    <!-- H1 — kinetic typography (CSS-only) -->
    <KineticText
      as="h1"
      lines={[
        { text: "Остался один канал." },
        { text: "Мы его строим.", className: "text-gradient-hero" },
      ]}
      className="h-display text-[clamp(2.5rem,10vw,8rem)] mb-8 max-w-[18ch]"
      stagger={0.09}
      delay={0.35}
    />

    <!-- Sub — 2-в-1 -->
    <p
      class="text-lg md:text-xl text-[var(--color-text-1)] max-w-[32ch] mb-12 leading-snug"
      data-reveal
      style="animation-delay:900ms"
    >
      Трафик и контент — в&nbsp;одном решении.
      <br />
      Над продакшеном думаем мы.
    </p>

    <!-- CTAs -->
    <div
      class="flex flex-col sm:flex-row items-center gap-4 mb-16"
      data-reveal
      style="animation-delay:1100ms"
    >
      <MagneticButton
        client:load
        href={TELEGRAM_BOT_URL}
        target="_blank"
        rel="noopener noreferrer"
        className="btn-primary"
      >
        <TelegramIcon size={18} />
        <span>Запустить поток</span>
      </MagneticButton>

      <a
        href={TELEGRAM_BOT_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="link-arrow flex items-center gap-2 text-base"
      >
        <TelegramIcon size={16} />
        <span>Написать в Telegram</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <!-- Platform strip -->
    <div
      class="flex flex-wrap items-center justify-center gap-2"
      data-reveal
      style="animation-delay:1300ms"
    >
      <span class="platform-chip animate-float" style="animation-delay:0ms">
        TikTok
      </span>
      <span class="platform-chip animate-float" style="animation-delay:300ms">
        Instagram&nbsp;Reels
      </span>
      <span class="platform-chip animate-float" style="animation-delay:600ms">
        YouTube&nbsp;Shorts
      </span>
      <span class="platform-chip animate-float" style="animation-delay:900ms">
        ВК&nbsp;Видео
      </span>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    aria-hidden="true"
    class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-[var(--color-text-2)] text-xs z-10"
  >
    <span class="font-mono uppercase tracking-widest">Листай</span>
    <span
      class="block w-[1px] h-8 bg-gradient-to-b from-[var(--color-accent)] to-transparent"
    ></span>
  </div>
</section>

<style>
  /* ── CSS Plasma Glow — replaces Three.js/R3F (saves ~1 MB JS) ── */
  .hero-plasma {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  /* Main amber halo — sits behind the ⚡ icon */
  .hero-plasma::before {
    content: "";
    position: absolute;
    top: 8%;
    left: 50%;
    width: min(780px, 80vw);
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(
      ellipse at center,
      rgba(255, 200, 0, 0.26) 0%,
      rgba(255, 140, 0, 0.16) 30%,
      rgba(255, 107, 53, 0.07) 60%,
      transparent 78%
    );
    filter: blur(64px);
    transform: translateX(-50%);
    animation: plasmaBreath 4.4s ease-in-out infinite;
    will-change: opacity, transform;
  }

  /* Secondary warm core — tighter, brighter */
  .hero-plasma::after {
    content: "";
    position: absolute;
    top: 6%;
    left: 50%;
    width: min(340px, 38vw);
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 185, 0, 0.42) 0%,
      rgba(255, 140, 0, 0.18) 45%,
      transparent 70%
    );
    filter: blur(36px);
    transform: translateX(-50%);
    animation: plasmaCore 5.8s ease-in-out infinite;
    will-change: opacity, transform;
  }

  @keyframes plasmaBreath {
    0%, 100% { opacity: 0.55; transform: translateX(-50%) scale(1); }
    50%       { opacity: 0.95; transform: translateX(-50%) scale(1.14); }
  }

  @keyframes plasmaCore {
    0%, 100% { opacity: 0.4;  transform: translateX(-50%) scale(1) rotate(0deg); }
    35%       { opacity: 0.85; transform: translateX(-47%) scale(1.22) rotate(6deg); }
    70%       { opacity: 0.5;  transform: translateX(-53%) scale(0.88) rotate(-4deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-plasma::before,
    .hero-plasma::after {
      animation: none;
      opacity: 0.6;
    }
  }
</style>
