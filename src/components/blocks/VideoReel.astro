---
// БЛОК — VIDEO REEL MOCK
// Два вертикальных видео в телефон-моках
---

<section class="block relative overflow-hidden">
  <div class="max-w-[1280px] mx-auto w-full">

    <div class="text-center mb-14" data-reveal>
      <div class="eyebrow mb-5 justify-center">Примеры роликов</div>
      <h2 class="h-display text-[clamp(1.75rem,4vw,3rem)]">
        Так выглядит <span class="text-gradient-hero">результат.</span>
      </h2>
    </div>

    <!-- Two phone mocks -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-8 md:gap-14">

      <!-- Phone mock 1 -->
      <div class="phone-mock" data-reveal style="animation-delay:100ms">
        <div class="phone-screen">
          <video
            src="/videos/video-1.mp4"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
          ></video>
        </div>
      </div>

      <!-- Phone mock 2 -->
      <div class="phone-mock" data-reveal style="animation-delay:220ms">
        <div class="phone-screen">
          <video
            src="/videos/video-2.mp4"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
          ></video>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Phone mock shell ── */
  .phone-mock {
    position: relative;
    width: 220px;
    flex-shrink: 0;
    /* border = phone body */
    border: 2.5px solid rgba(255, 255, 255, 0.12);
    border-radius: 36px;
    padding: 10px;
    background: #0a0807;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.04),
      0 24px 60px -12px rgba(0, 0, 0, 0.7),
      0 0 40px rgba(255, 204, 0, 0.06);
    transition: transform 400ms cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 400ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .phone-mock:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow:
      0 0 0 1px rgba(255,204,0,0.15),
      0 32px 80px -12px rgba(0, 0, 0, 0.8),
      0 0 60px rgba(255, 204, 0, 0.12);
  }

  /* Notch */
  .phone-mock::before {
    content: '';
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 6px;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.1);
    z-index: 2;
  }

  .phone-screen {
    border-radius: 28px;
    overflow: hidden;
    aspect-ratio: 9 / 16;
    background: #000;
    position: relative;
  }

  .phone-screen video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Responsive — bigger on desktop */
  @media (min-width: 768px) {
    .phone-mock {
      width: 260px;
    }
  }

  @media (min-width: 1280px) {
    .phone-mock {
      width: 290px;
    }
  }
</style>
