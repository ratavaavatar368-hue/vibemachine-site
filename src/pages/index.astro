---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/blocks/Hero.astro";
import Diagnosis from "../components/blocks/Diagnosis.astro";
import Studio from "../components/blocks/Studio.astro";
import Pricing from "../components/blocks/Pricing.astro";
import FAQ from "../components/blocks/FAQ.astro";
import CTA from "../components/blocks/CTA.astro";
---

<BaseLayout>
  <Header />
  <!-- pt-[4.25rem] = clearance for fixed header (~68px) on all viewport sizes -->
  <main class="pt-[4.25rem]">
    <Hero />
    <Diagnosis />
    <Studio />
    <Pricing />
    <FAQ />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
